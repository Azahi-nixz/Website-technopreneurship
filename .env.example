# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the commercial e-commerce website
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1: full connection string (takes priority over individual variables)
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce

# Option 2: individual connection parameters (used when DATABASE_URL is unset)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=user
DB_PASSWORD=password

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
# A long, random string used to sign session cookies.
# REQUIRED in production — set this in Vercel Environment Variables.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ── Flask-Session ─────────────────────────────────────────────────────────────
# "cookie"     — Flask built-in signed cookies (default, works on Vercel)
# "filesystem" — local filesystem (dev only)
# "redis"      — Redis backend (requires REDIS_URL)
SESSION_TYPE=filesystem

# ── Security ──────────────────────────────────────────────────────────────────
# Set to 1 in production to enforce HTTPS-only cookies
SESSION_COOKIE_SECURE=0
